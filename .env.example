# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Database (Postgres — Neon, Supabase, or local) ───────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/khoidoanh
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/khoidoanh

# ─── Auth.js ──────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── LLM (OSS, OpenAI-compatible) ─────────────────────────────────────
# Default: Ollama on localhost. For production swap to vLLM/SGLang on a
# GPU node and point LLM_BASE_URL at the gateway. No managed-API providers.
# Pull models: `ollama pull qwen2.5:32b-instruct qwen2.5:7b-instruct`
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=qwen2.5:7b-instruct
# Production GPU: bump LLM_MODEL to qwen2.5:32b-instruct. Charter generation
# benefits from the larger model — 7b is fine for company-name + business-codes.

# ─── Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# ─── Upstash Redis (rate limit + session) ─────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_
EMAIL_FROM=noreply@khoidoanh.ai

# ─── File storage (Vercel Blob) ───────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Observability (optional) ─────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Cổng thông tin DKKD quốc gia (Bộ KH&ĐT) ─────────────────────────
# Production credentials cấp bởi Bộ KH&ĐT khi onboard
DKKD_NATIONAL_PORTAL_API_KEY=
