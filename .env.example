# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Database (Postgres — Neon, Supabase, or local) ───────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/khoidoanh
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/khoidoanh

# ─── Auth.js ──────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Anthropic Claude ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-opus-4-7

# ─── Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# ─── Upstash Redis (rate limit + session) ─────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_
EMAIL_FROM=noreply@khoidoanh.ai

# ─── File storage (Vercel Blob) ───────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Observability (optional) ─────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Cổng thông tin DKKD quốc gia (Bộ KH&ĐT) ─────────────────────────
# Production credentials cấp bởi Bộ KH&ĐT khi onboard
DKKD_NATIONAL_PORTAL_API_KEY=
